# wa-manager — environment variables
# Copy to .env and fill in real values. Never commit .env.

# ── Database ──────────────────────────────────────────────────────────────────
# Railway auto-sets this when you add a Postgres service
DATABASE_URL=postgres://user:password@host:5432/wamanager?sslmode=require

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=change-me-to-a-long-random-string
ADMIN_USERNAME=admin
ADMIN_PASSWORD=change-me

# ── Meta / WhatsApp Cloud API ─────────────────────────────────────────────────
# dashboard.developers.facebook.com → your app → WhatsApp → API Setup
META_PHONE_NUMBER_ID=
META_ACCESS_TOKEN=
META_WABA_ID=
META_APP_ID=
META_APP_SECRET=
OLD_META_APP_SECRET=        # for zero-downtime secret rotation

# Webhook verify token — set this same value in Meta's webhook config
META_WEBHOOK_VERIFY_TOKEN=

# ── Frontend ──────────────────────────────────────────────────────────────────
FRONTEND_URL=https://your-frontend.pages.dev  # or https://your-frontend.up.railway.app

# ── Server ────────────────────────────────────────────────────────────────────
PORT=8080                   # Railway sets this automatically
